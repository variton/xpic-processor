alias reload=". ~/.bashrc"
alias scan-dir="du -h . | sort -h"
alias scan-fs="sudo du -h --max-depth=1 / | sort -h"
alias domains="cat /etc/hosts"
alias check-leak="valgrind --leak-check=full"
alias b-debug="cd $LAB;clear;./build.sh debug"
alias b-release="cd $LAB;clear;./build.sh release"
alias b-clean="cd $LAB;clear;./build.sh clean"
alias rebuild="clear;b-clean;b-debug"
